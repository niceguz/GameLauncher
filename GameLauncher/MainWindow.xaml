<Window x:Class="GameLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameLauncher"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DockPanel>

            <!-- 상단 메뉴 -->
            <Menu DockPanel.Dock="Top">

                <MenuItem Header="파일">
                    <MenuItem Header="게임 추가" Click="AddGame_Click"/>
                    <Separator/>
                </MenuItem>

                <MenuItem Header="보기">
                    <MenuItem Header="이름순 정렬" Click="SortByName_Click"/>
                </MenuItem>

                <MenuItem Header="도움말">
                </MenuItem>

            </Menu>

            <!-- 기존 UI -->
            <StackPanel Margin="10">
                <ListBox x:Name="GameList" DisplayMemberPath="Name" Height="200"/>
                <Button Content="게임 실행" Click="RunGame_Click" Margin="0,10,0,0"/>
            </StackPanel>

        </DockPanel>
    </Grid>
</Window>
